{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bifrost",
  "version": "0.1.0",
  "identifier": "com.bifrost.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bifrost — Phone ↔ PC Bridge",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "center": true
      },
      {
        "label": "mirror",
        "title": "Bifrost Mirror",
        "url": "/#/mirror-window",
        "width": 400,
        "height": 800,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["/tmp/**", "$HOME/Downloads/Bifrost/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/scrcpy-server.jar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
